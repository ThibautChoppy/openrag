{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["persistence", "openrag"],
  "properties": {
    "persistence": {
      "type": "object",
      "required": ["storageClass"],
      "properties": {
        "storageClass": { "type": "string", "minLength": 1 }
      }
    },
    "openrag": {
      "type": "object",
      "properties": {
        "replicas": { "type": "integer", "minimum": 1 }
      }
    },
    "env": {
      "type": "object",
      "properties": {
        "secretsProvider": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["values", "externalSecret", "vaultStaticSecret"]
            }
          }
        }
      }
    }
  }
}
